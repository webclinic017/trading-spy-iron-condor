# Copy to .env.devloop and set values for launchd runtime.
# Do not commit .env.devloop.

# Tetrate / Gateway
LLM_GATEWAY_BASE_URL=
LLM_GATEWAY_API_KEY=
TETRATE_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional pricing for scorecards
TARS_INPUT_COST_PER_1M=0.50
TARS_OUTPUT_COST_PER_1M=1.50

# Optional: sync explainer markdown into a Google Doc each cycle.
SYNC_GDOC=0
GDRIVE_DOC_URL=
GDRIVE_CREDS_FILE=.secrets/google-service-account.json
